{
  "name": "@svmukhin/edible-css",
  "version": "1.2.1",
  "description": "A primitive, classless CSS framework for developers with no design skills. Style semantic HTML5 with a single <link> tag.",
  "main": "dist/edible.css",
  "style": "dist/edible.css",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/edible.css",
    "dist/edible.min.css"
  ],
  "scripts": {
    "build": "postcss src/edible.css -o dist/edible.css",
    "minify": "postcss dist/edible.css -o dist/edible.min.css --no-map --use cssnano",
    "validate": "echo 'CSS validation skipped - using manual W3C validator'",
    "test:a11y": "pa11y-ci test/samples/*.html",
    "serve:tests": "python3 -m http.server 8080",
    "test": "npm run validate && npm run test:a11y",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "lint:license": "reuse lint",
    "predeploy": "npm run build && npm run minify",
    "deploy": "gh-pages -d docs -m 'Deploy documentation [ci skip]'"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/svmukhin/edible-css"
  },
  "keywords": [
    "css",
    "classless",
    "framework",
    "semantic-html",
    "no-classes",
    "drop-in"
  ],
  "author": "Sergei Mukhin",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/svmukhin/edible-css/issues"
  },
  "homepage": "https://svmukhin.github.io/edible-css/",
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "cssnano": "^7.1.2",
    "gh-pages": "^6.3.0",
    "markdownlint-cli2": "^0.21.0",
    "pa11y": "^9.1.1",
    "pa11y-ci": "^4.1.0",
    "postcss": "^8.5.0",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.1.0"
  }
}
